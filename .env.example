# ─── Jenkins ───────────────────────────────────────────────────────────────────
JENKINS_URL=http://your-jenkins-host:8080
JENKINS_USER=admin
JENKINS_TOKEN=

# Webhook HMAC secret — must match the "Secret" field in the Jenkins plugin config.
# Leave blank to disable signature verification (not recommended in production).
JENKINS_WEBHOOK_SECRET=

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/jenkins_log_intel

# ─── Redis / Celery broker ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Slack ─────────────────────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps, add the chat:write scope,
# install it to your workspace, and paste the Bot User OAuth Token here.
SLACK_BOT_TOKEN=xoxb-
SLACK_DEFAULT_CHANNEL=#build-alerts

# ─── LLM — Groq (primary, fast, free tier available) ──────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=gsk_
GROQ_MODEL=llama-3.3-70b-versatile

# ─── LLM — Anthropic Claude (fallback) ────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token with repo:read scope — used to fetch Jenkinsfiles
# from private repositories.
GITHUB_TOKEN=

# Webhook HMAC secret — must match the "Secret" field in your GitHub webhook settings.
GITHUB_WEBHOOK_SECRET=

# ─── Email notifications (optional) ───────────────────────────────────────────
SENDER_EMAIL=cibot@yourdomain.com
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ─── ngrok (optional — used to auto-detect public tunnel URL) ─────────────────
# Override if ngrok runs on a non-default port or a remote machine.
NGROK_API_URL=http://localhost:4040

# ─── Scheduler / feature flags ─────────────────────────────────────────────────
MAX_CONCURRENT_EXECUTIONS=6
AUTO_SEED_WORKERS=false
ALLOW_SYNTHETIC_PIPELINE_STAGES=false
